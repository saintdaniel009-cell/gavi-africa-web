---
// Header with logo + nav. `activePage` highlights the current page.
const {activePage = ''} = Astro.props

const navItems = [
  {href: '/vehicles', label: 'Vehicles', key: 'vehicles'},
  {href: '/services', label: 'Services', key: 'services'},
  {href: '/about',    label: 'About',    key: 'about'},
  {href: '/blog',     label: 'Blog',     key: 'blog'},
  {href: '/contact',  label: 'Contact',  key: 'contact'},
]
---

<header class="header">
  <div class="container">
    <a href="/" class="logo" aria-label="GAVI AFRICA LIMITED home">
      <img src="/images/gavi-logo.png" alt="GAVI AFRICA" class="logo-img" />
    </a>
    <nav aria-label="Main navigation">
      <ul class="nav-links">
        {navItems.map(item => (
          <li>
            <a href={item.href} class:list={[{active: activePage === item.key}]}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <a href="/#booking" class="btn btn-primary header-cta">Book a Service →</a>
    <button class="hamburger" id="hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile menu (slides down under the header on small screens) -->
  <nav class="mobile-menu" id="mobile-menu" aria-label="Mobile navigation" hidden>
    <ul>
      {navItems.map(item => (
        <li>
          <a href={item.href} class:list={[{active: activePage === item.key}]}>
            {item.label}
          </a>
        </li>
      ))}
      <li class="mobile-menu-cta">
        <a href="/#booking" class="btn btn-primary" style="width: 100%;">Book a Service →</a>
      </li>
    </ul>
  </nav>
</header>

<style>
  .mobile-menu {
    display: none;
    background: var(--paper);
    border-bottom: 1px solid var(--line);
    box-shadow: 0 16px 32px rgba(15, 26, 43, 0.08);
  }
  .mobile-menu.is-open { display: block; }
  @media (min-width: 880px) { .mobile-menu.is-open { display: none; } }
  .mobile-menu ul {
    list-style: none;
    padding: var(--s-3) var(--s-5) var(--s-6);
    margin: 0;
  }
  .mobile-menu li { border-bottom: 1px solid var(--line); }
  .mobile-menu li:last-child { border-bottom: none; }
  .mobile-menu a:not(.btn) {
    display: block;
    padding: var(--s-4) 0;
    font-size: 16px;
    font-weight: 600;
    color: var(--ink-soft);
  }
  .mobile-menu a.active { color: var(--gavi-blue); }
  .mobile-menu-cta { padding-top: var(--s-4); }

  /* Hamburger → X animation */
  .hamburger span { transition: transform 0.2s ease, opacity 0.2s ease; }
  .hamburger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.is-open span:nth-child(2) { opacity: 0; }
  .hamburger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
</style>

<script>
  const burger = document.getElementById('hamburger')
  const menu = document.getElementById('mobile-menu')
  if (burger && menu) {
    const setOpen = (open) => {
      menu.hidden = !open
      menu.classList.toggle('is-open', open)
      burger.classList.toggle('is-open', open)
      burger.setAttribute('aria-expanded', String(open))
      burger.setAttribute('aria-label', open ? 'Close menu' : 'Open menu')
    }
    burger.addEventListener('click', () => setOpen(menu.hidden))
    // Close when a link is tapped (so same-page anchors like /#booking work cleanly)
    menu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => setOpen(false)))
  }
</script>
