---
import {urlFor} from '../lib/sanity.js'

const {post, featured = false} = Astro.props
const imgUrl = post.coverImage ? urlFor(post.coverImage).width(featured ? 1200 : 800).height(featured ? 900 : 600).fit('crop').url() : null
const imgAlt = post.coverImage?.alt || post.title
const dateStr = post.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString('en-GB', {month: 'short', year: 'numeric'})
  : ''
---

{featured ? (
  <article class="featured-card">
    <div class="featured-photo">
      {imgUrl && <img src={imgUrl} alt={imgAlt} loading="eager" />}
    </div>
    <div>
      <div class="featured-meta">
        <span class="cat">{post.category}</span>
        <span>{post.readTime} min read</span>
        <span>{dateStr}</span>
      </div>
      <h2 class="featured-title">{post.title}</h2>
      <p class="featured-excerpt">{post.excerpt}</p>
      <a href={`/blog/${post.slug}`} class="btn btn-primary">Read the full post →</a>
    </div>
  </article>
) : (
  <article class="blog-card">
    <a href={`/blog/${post.slug}`} style="display: block;">
      <div class="blog-card-photo">
        {imgUrl && <img src={imgUrl} alt={imgAlt} loading="lazy" />}
      </div>
    </a>
    <div class="blog-card-body">
      <div class="blog-card-meta">{post.category} <span class="dot"></span> <span class="time">{post.readTime} min read</span></div>
      <h3 class="blog-card-title">{post.title}</h3>
      <p class="blog-card-excerpt">{post.excerpt}</p>
      <a href={`/blog/${post.slug}`} class="blog-card-cta">Read post →</a>
    </div>
  </article>
)}

<style>
  /* Featured card */
  .featured-card { display: grid; gap: var(--s-8); grid-template-columns: 1fr; align-items: center; }
  @media (min-width: 880px) { .featured-card { grid-template-columns: 1.15fr 1fr; gap: var(--s-12); } }
  .featured-photo {
    aspect-ratio: 4 / 3; border-radius: 16px; overflow: hidden;
    background: var(--paper-soft); box-shadow: 0 16px 40px rgba(15, 26, 43, 0.10);
  }
  .featured-photo img { width: 100%; height: 100%; object-fit: cover; }
  .featured-meta {
    display: flex; gap: var(--s-3); align-items: center; margin-bottom: var(--s-4);
    font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-mute);
  }
  .featured-meta .cat { color: var(--gavi-blue); padding: 4px 10px; background: var(--gavi-blue-tint); border-radius: 4px; }
  .featured-title { font-size: 32px; line-height: 1.15; margin-bottom: var(--s-4); }
  @media (min-width: 880px) { .featured-title { font-size: 40px; } }
  .featured-excerpt { font-size: 17px; color: var(--ink-soft); line-height: 1.6; margin-bottom: var(--s-6); }

  /* Grid card */
  .blog-card {
    background: var(--paper); border: 1px solid var(--line); border-radius: 14px;
    overflow: hidden; display: flex; flex-direction: column;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .blog-card:hover { transform: translateY(-4px); border-color: var(--gavi-blue); box-shadow: 0 16px 36px rgba(15, 26, 43, 0.08); }
  .blog-card-photo { aspect-ratio: 4 / 3; overflow: hidden; background: var(--paper-soft); border-bottom: 1px solid var(--line); }
  .blog-card-photo img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
  .blog-card:hover .blog-card-photo img { transform: scale(1.05); }
  .blog-card-body { padding: var(--s-5); flex-grow: 1; display: flex; flex-direction: column; gap: var(--s-3); }
  .blog-card-meta { font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 700; color: var(--gavi-blue); }
  .blog-card-meta .dot { display: inline-block; width: 3px; height: 3px; border-radius: 50%; background: var(--ink-mute); vertical-align: middle; margin: 0 var(--s-2); }
  .blog-card-meta .time { color: var(--ink-mute); font-weight: 500; }
  .blog-card-title { font-size: 18px; line-height: 1.25; }
  .blog-card-excerpt { font-size: 14px; color: var(--ink-mute); line-height: 1.55; flex-grow: 1; }
  .blog-card-cta { color: var(--gavi-blue); font-size: 13px; font-weight: 700; padding-top: var(--s-3); border-top: 1px solid var(--line); display: inline-flex; align-items: center; gap: 6px; }
</style>
