---
import Base from '../../layouts/Base.astro'
import {sanityClient, urlFor} from '../../lib/sanity.js'
import {allPostSlugsQuery, postBySlugQuery} from '../../lib/queries.js'
import {toHTML} from '@portabletext/to-html'

export async function getStaticPaths() {
  const slugs = await sanityClient.fetch(allPostSlugsQuery)
  return slugs.map((slug) => ({params: {slug}}))
}

const {slug} = Astro.params
const post = await sanityClient.fetch(postBySlugQuery, {slug})
if (!post) return Astro.redirect('/blog')

// Convert Sanity Portable Text -> HTML. Custom serializers for h2/h3/images
// so they get sensible defaults.
const bodyHtml = toHTML(post.body || [], {
  components: {
    types: {
      image: ({value}) => {
        const url = urlFor(value).width(1200).url()
        const alt = value.alt || ''
        const caption = value.caption
        return caption
          ? `<figure><img src="${url}" alt="${alt}" loading="lazy" /><figcaption>${caption}</figcaption></figure>`
          : `<img src="${url}" alt="${alt}" loading="lazy" />`
      },
    },
    marks: {
      link: ({children, value}) => `<a href="${value.href}" target="_blank" rel="noopener">${children}</a>`,
    },
  },
})

const heroImg = post.coverImage ? urlFor(post.coverImage).width(1600).height(900).fit('crop').url() : null
const dateStr = post.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString('en-GB', {day: 'numeric', month: 'long', year: 'numeric'})
  : ''
---

<Base
  title={`${post.title} — GAVI AFRICA Blog`}
  description={post.excerpt}
  activePage="blog"
>
  <article class="post">
    <header class="post-header">
      <div class="container">
        <nav class="breadcrumbs">
          <a href="/">Home</a><span class="crumb-sep">/</span>
          <a href="/blog">Blog</a><span class="crumb-sep">/</span>
          {post.category}
        </nav>
        <div class="post-meta">
          <span class="cat">{post.category}</span>
          <span>{post.readTime} min read</span>
          <span>{dateStr}</span>
        </div>
        <h1>{post.title}</h1>
        <p class="post-excerpt">{post.excerpt}</p>
      </div>
    </header>

    {heroImg && (
      <div class="container">
        <img src={heroImg} alt={post.coverImage?.alt || post.title} class="post-hero-photo" />
      </div>
    )}

    <div class="container">
      <div class="post-body" set:html={bodyHtml} />
    </div>

    <div class="container">
      <div class="post-cta">
        <h3>Talk to us about your car.</h3>
        <p>Something in this post ring a bell? Book a service or send us a WhatsApp.</p>
        <div style="display:flex; gap: var(--s-3); flex-wrap: wrap;">
          <a href="/#booking" class="btn btn-primary">Book a Service →</a>
          <a href="https://wa.me/2348079000009" class="btn btn-outline">WhatsApp us</a>
        </div>
      </div>
    </div>
  </article>
</Base>

<style>
  .post-header { padding: var(--s-16) 0 var(--s-10); background: var(--paper); }
  .post-meta {
    display: flex; gap: var(--s-3); align-items: center; margin-bottom: var(--s-4);
    font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-mute);
  }
  .post-meta .cat { color: var(--gavi-blue); padding: 4px 10px; background: var(--gavi-blue-tint); border-radius: 4px; }
  .post-header h1 { font-size: 40px; line-height: 1.1; margin-bottom: var(--s-5); max-width: 820px; }
  @media (min-width: 760px) { .post-header h1 { font-size: 52px; } }
  .post-excerpt { font-size: 20px; color: var(--ink-soft); line-height: 1.5; max-width: 720px; font-weight: 500; }
  .post-hero-photo {
    width: 100%; max-width: 1000px; margin: 0 auto var(--s-12);
    border-radius: 16px; aspect-ratio: 16/9; object-fit: cover;
    box-shadow: 0 16px 40px rgba(15, 26, 43, 0.10);
  }
  .post-body { max-width: 720px; margin: 0 auto var(--s-16); font-size: 17px; line-height: 1.75; color: var(--ink-soft); }
  .post-body :global(h2) { font-size: 28px; margin: var(--s-10) 0 var(--s-4); color: var(--ink); }
  .post-body :global(h3) { font-size: 22px; margin: var(--s-8) 0 var(--s-3); color: var(--ink); }
  .post-body :global(p) { margin-bottom: var(--s-5); }
  .post-body :global(ul), .post-body :global(ol) { margin: 0 0 var(--s-5) var(--s-6); }
  .post-body :global(li) { margin-bottom: var(--s-2); }
  .post-body :global(a) { color: var(--gavi-blue); border-bottom: 1.5px solid var(--gavi-blue); }
  .post-body :global(img) { width: 100%; border-radius: 12px; margin: var(--s-8) 0; }
  .post-body :global(blockquote) {
    border-left: 4px solid var(--gavi-blue); padding: var(--s-4) 0 var(--s-4) var(--s-5);
    margin: var(--s-8) 0; color: var(--ink); font-style: italic;
  }
  .post-cta {
    max-width: 720px; margin: 0 auto var(--s-16); padding: var(--s-8);
    background: var(--paper-soft); border-radius: 16px; text-align: center;
  }
  .post-cta h3 { font-size: 24px; margin-bottom: var(--s-3); }
  .post-cta p { color: var(--ink-mute); margin-bottom: var(--s-5); }
</style>
