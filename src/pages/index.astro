---
import Base from '../layouts/Base.astro'
import OemMarquee from '../components/OemMarquee.astro'
---

<Base activePage="">
<!-- ============ SECTION C: Hero — NEW (duotone illustration, single CTA) ============ -->
  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-text">
          <h1 class="hero-headline">
            Trusted automotive <span class="blue-word">service</span>, sales, and spare parts in Lagos.
          </h1>
          <p class="hero-copy">
            GAVI AFRICA LIMITED runs an auto experience centre for individuals, families, and any fleet in Lagos and Nigeria. Brand-trained technicians. OEM parts. Warranty that holds. One Centre.
          </p>
          <div class="hero-cta-row">
            <a href="#booking" class="btn btn-primary">Book a Service →</a>
            <a href="/vehicles" class="text-link">or browse vehicles for sale</a>
          </div>
        </div>

        <!-- DUOTONE HERO ILLUSTRATION
             Stylized service-bay scene — car on lift, workshop lighting.
             Built as SVG so it scales perfectly and renders in two brand tones.
             Swap for a real duotone-treated photograph once available
             (apply same #246EB6 + #0F1A2B duotone treatment).
        -->
        <div class="hero-carousel" data-carousel>
          <div class="carousel-slides">
            <figure class="carousel-slide is-active">
              <img src="/images/facility-front.jpg" alt="GAVI AFRICA Auto Experience Centre — front view" loading="eager">
            </figure>
            <figure class="carousel-slide">
              <img src="/images/workshop-bay.jpg" alt="Workshop bay with vehicles in for service" loading="lazy">
            </figure>
            <figure class="carousel-slide">
              <img src="/images/team-balcony.jpg" alt="The GAVI AFRICA technician team" loading="lazy">
            </figure>
            <figure class="carousel-slide">
              <img src="/images/diagnostic-tablet.jpg" alt="Technician running vehicle diagnostics with tablet" loading="lazy">
            </figure>
            <figure class="carousel-slide">
              <img src="/images/facility-aerial-angle.jpg" alt="Aerial view of the GAVI AFRICA compound" loading="lazy">
            </figure>
          </div>
          <div class="carousel-controls" role="tablist" aria-label="Choose hero image">
            <button type="button" class="carousel-dot is-active" data-idx="0" aria-label="Slide 1"></button>
            <button type="button" class="carousel-dot" data-idx="1" aria-label="Slide 2"></button>
            <button type="button" class="carousel-dot" data-idx="2" aria-label="Slide 3"></button>
            <button type="button" class="carousel-dot" data-idx="3" aria-label="Slide 4"></button>
            <button type="button" class="carousel-dot" data-idx="4" aria-label="Slide 5"></button>
          </div>
          <div class="hero-badge">
            <span class="hero-badge-dot"></span>
            Auto Experience Centre · Abule-Egba, Lagos
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SECTION D: Trust strip — NEW (with explainer caption) ============ -->
  <section class="trust-strip" aria-label="OEM partners">
    <div class="container">
      <div class="trust-label">Genuine Parts &amp; Trusted Automotive Partners</div>
      <OemMarquee />
      <p class="trust-caption">
        Working with <strong>Toyota, Bosch, Denso, Aisin, Advics,</strong> and OEM manufacturers across the industry. Genuine parts, sourced across our supply network.
      </p>
    </div>
  </section>

  <!-- ============ SECTION E: Three Pillars — NEW (custom hex-framed illustrations) ============ -->
  <section>
    <div class="container">
      <div class="center" style="margin-bottom: var(--s-10);">
        <span class="eyebrow">Three Pillars · One Centre</span>
        <h2 class="section-title">Sales. Service. <span class="blue-word">Spare Parts.</span></h2>
        <p class="section-lede">Everything we do at our Auto Experience Centre in Abule-Egba, Lagos sits inside one of these three pillars.</p>
      </div>
      <div class="pillars-grid">

        <!-- Pillar 1: Vehicle Sales -->
        <div class="pillar-card">
          <div class="pillar-illustration" aria-hidden="true"><img src="/images/pillar-vehicles.png" alt="Vehicle Sales icon" class="pillar-icon-img"></div>
          <h3>Vehicle Sales</h3>
          <ul>
            <li>Brand new vehicles, sourced and inspected</li>
            <li>Quality pre-owned, verified by our team</li>
            <li>Transparent pricing &amp; full documentation</li>
            <li>3-year / 100,000 km warranty on new vehicles</li>
          </ul>
          <a href="/vehicles" class="btn btn-ghost">Explore vehicles →</a>
        </div>

        <!-- Pillar 2: After-Sales Service -->
        <div class="pillar-card">
          <div class="pillar-illustration" aria-hidden="true"><img src="/images/pillar-service.png" alt="After-Sales Service icon" class="pillar-icon-img"></div>
          <h3>After-Sales Service</h3>
          <ul>
            <li>Routine maintenance &amp; periodic servicing</li>
            <li>Diagnostics, running repairs &amp; warranty work</li>
            <li>Body &amp; paint, with show-room finish</li>
            <li>Mobile workshop for fleets (min. 3 vehicles)</li>
          </ul>
          <a href="/services" class="btn btn-ghost">View services →</a>
        </div>

        <!-- Pillar 3: Genuine Spare Parts -->
        <div class="pillar-card">
          <div class="pillar-illustration" aria-hidden="true"><img src="/images/pillar-parts.png" alt="Genuine Spare Parts icon" class="pillar-icon-img"></div>
          <h3>Genuine Spare Parts</h3>
          <ul>
            <li>Multi-brand OEM components, not Toyota-only</li>
            <li>Toyota, Bosch, Denso, Aisin, Advics &amp; more</li>
            <li>Supply for walk-in, fleet &amp; workshop accounts</li>
            <li>Sourced beyond our flagship partnerships</li>
          </ul>
          <a href="parts.html" class="btn btn-ghost">Request parts →</a>
        </div>

      </div>
    </div>
  </section>

  <!-- ============ SECTION F: Testimonials — NEW (3 strongest + Google link) ============ -->
  <section class="testimonials">
    <div class="container">
      <div class="center" style="margin-bottom: var(--s-10);">
        <span class="eyebrow">In Their Words</span>
        <h2 class="section-title">What our customers are saying.</h2>
      </div>
      <div class="testimonials-grid">

        <!-- Testimonial 1: Emotional/specific (parents' car) -->
        <div class="testimonial">
          <div class="stars" aria-label="5 out of 5 stars">★★★★★</div>
          <p class="testimonial-quote">"Thanks for your team's expertise in fixing my parents' car. My Dad had good feedback from the work. God bless you."</p>
          <span class="testimonial-tag">Family vehicle · repair</span>
          <div class="testimonial-author">
            <div class="avatar">L</div>
            <div><div class="author-name">Laughter</div><div class="author-context">Verified customer</div></div>
          </div>
        </div>

        <!-- Testimonial 2: Referral signal (business value) -->
        <div class="testimonial">
          <div class="stars" aria-label="5 out of 5 stars">★★★★★</div>
          <p class="testimonial-quote">"Good morning, well done. My friend is very impressed with the quality of your work and she is a sure gateway to more referrals."</p>
          <span class="testimonial-tag">Word-of-mouth referral</span>
          <div class="testimonial-author">
            <div class="avatar">A</div>
            <div><div class="author-name">Ayokanmi</div><div class="author-context">Verified customer</div></div>
          </div>
        </div>

        <!-- Testimonial 3: Concrete outcome (diagnostic resolved) -->
        <div class="testimonial">
          <div class="stars" aria-label="5 out of 5 stars">★★★★★</div>
          <p class="testimonial-quote">"The car is not doing hard starting again. Thank you."</p>
          <span class="testimonial-tag">Diagnostic &amp; repair</span>
          <div class="testimonial-author">
            <div class="avatar">A</div>
            <div><div class="author-name">Azeez</div><div class="author-context">Verified customer</div></div>
          </div>
        </div>

      </div>
      <div class="reviews-footer">
        <p class="reviews-footer-text">More stories from people we've served.</p>
        <a href="#" class="btn btn-outline">Read more reviews on Google →</a>
      </div>
    </div>
  </section>

  <!-- ============ SECTION G: Booking — NEW (integrated 4-step process + specialty chips) ============ -->
  <section id="booking" class="booking">
    <div class="container">

      <!-- Integrated 4-step process (replaces standalone How-It-Works section) -->
      <div class="process-row" aria-label="How booking works">
        <div class="process-step">
          <span class="process-step-num" aria-hidden="true">1</span>
          <div>
            <h4>Book</h4>
            <p>Fill the form, call, or WhatsApp us.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="process-step-num" aria-hidden="true">2</span>
          <div>
            <h4>Diagnose</h4>
            <p>We inspect. You see the quote first.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="process-step-num" aria-hidden="true">3</span>
          <div>
            <h4>Service</h4>
            <p>Brand-trained techs. OEM parts.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="process-step-num" aria-hidden="true">4</span>
          <div>
            <h4>Drive away</h4>
            <p>Quality check. Keys back. Done.</p>
          </div>
        </div>
      </div>

      <div class="booking-grid">

        <div class="booking-copy">
          <span class="eyebrow">Book a Service</span>
          <h2>Tell us what's wrong. We'll handle the rest.</h2>
          <p>Fill the form and we'll call you back. Want to speak to someone now? Ring the Service Advisor. They're at the desk during work hours.</p>

          <div class="booking-call">
            <span class="booking-call-label">Service Advisor / Customer Support</span>
            <a href="tel:+2347053009305" class="booking-call-number">+234 705 300 9305</a>
            <span style="font-size: 13px; color: var(--ink-mute);">Calls, SMS, WhatsApp · Mon–Fri 8AM–5PM, Sat 8AM–2PM</span>
          </div>

          <!-- Specialty service chips (replaces dark VAS section) -->
          <div class="specialty-chips-label">Specialty drop-off options</div>
          <div class="specialty-chips">
            <span class="specialty-chip"><span class="specialty-chip-code">EBS</span> Early Bird · from 6:30 AM</span>
            <span class="specialty-chip"><span class="specialty-chip-code">ONS</span> Overnight</span>
            <span class="specialty-chip"><span class="specialty-chip-code">WES</span> Weekend (Sat)</span>
            <span class="specialty-chip"><span class="specialty-chip-code">MWS</span> Mobile Workshop · fleet 3+</span>
            <span class="specialty-chip"><span class="specialty-chip-code">ERS</span> Emergency Recovery</span>
          </div>
          <p class="specialty-chip-tc">
            T&amp;Cs apply to all off-hours and mobile services. Select your preference in the drop-off section of the form.
          </p>
        </div>

        <form class="booking-form" id="booking-form" aria-label="Service booking form">
          <div class="field-row">
            <div class="field">
              <label for="bf-first">First name *</label>
              <input id="bf-first" name="first" type="text" required>
            </div>
            <div class="field">
              <label for="bf-last">Last name *</label>
              <input id="bf-last" name="last" type="text" required>
            </div>
          </div>
          <div class="field-row">
            <div class="field">
              <label for="bf-phone">Phone number *</label>
              <input id="bf-phone" name="phone" type="tel" placeholder="+234..." required>
            </div>
            <div class="field">
              <label for="bf-email">Email address *</label>
              <input id="bf-email" name="email" type="email" required>
            </div>
          </div>
          <div class="field-row">
            <div class="field">
              <label for="bf-brand">Vehicle brand *</label>
              <input id="bf-brand" name="brand" type="text" placeholder="e.g. Toyota" required>
            </div>
            <div class="field">
              <label for="bf-model">Model &amp; year *</label>
              <input id="bf-model" name="model" type="text" placeholder="e.g. Camry 2019" required>
            </div>
          </div>
          <div class="field">
            <label for="bf-vin">VIN / Chassis number <span class="hint">(optional but recommended)</span></label>
            <input id="bf-vin" name="vin" type="text" placeholder="Helps us prepare the right parts before you arrive.">
          </div>
          <div class="field">
            <label for="bf-service">Service required *</label>
            <select id="bf-service" name="service" required>
              <option value="">Select a service</option>
              <option>Quick service: every 5,000 km routine (QS)</option>
              <option>Free first service: 1,000 km, new vehicles (FS)</option>
              <option>Periodic maintenance (PMS)</option>
              <option>Annual maintenance (AMS)</option>
              <option>Preventive service</option>
              <option>Diagnostic service (DS)</option>
              <option>Running repair (RR)</option>
              <option>Body &amp; paint repair (BPR)</option>
              <option>Warranty repair (WR)</option>
              <option>Emergency recovery (ERS)</option>
              <option>Mobile workshop service: fleet 3+ (MWS)</option>
              <option>Overnight service (ONS)</option>
              <option>Weekend service (WES)</option>
              <option>After-market installation (AM)</option>
              <option>Spare parts enquiry</option>
              <option>Vehicle sales enquiry</option>
              <option>Other / not sure</option>
            </select>
          </div>
          <div class="field">
            <label for="bf-issue">Describe the issue <span class="hint">(optional)</span></label>
            <textarea id="bf-issue" name="issue" placeholder="Noises, warning lights, fluid leaks, mileage, etc."></textarea>
          </div>
          <div class="field">
            <label>Drop-off preference</label>
            <div class="radio-group">
              <label class="radio-option"><input type="radio" name="dropoff" value="standard" checked> Standard drop-off</label>
              <label class="radio-option"><input type="radio" name="dropoff" value="earlybird"> Early Bird (from 6:30 AM)</label>
              <label class="radio-option"><input type="radio" name="dropoff" value="saturday"> Saturday morning</label>
              <label class="radio-option"><input type="radio" name="dropoff" value="mobile"> Mobile or Recovery</label>
            </div>
          </div>
          <button type="submit" class="btn btn-primary" style="width: 100%; padding: 18px;">Request Diagnosis →</button>
        </form>

      </div>
    </div>
  </section>

  <!-- ============ SECTION H: Trusted By (corporate clients) ============ -->
  <section class="trusted-by">
    <div class="container">
      <div class="center" style="margin-bottom: var(--s-10);">
        <span class="eyebrow">Trusted By</span>
        <h2 class="section-title">Brands &amp; institutions <span class="blue-word">we've served</span>.</h2>
        <p class="section-lede">Financial institutions, schools, and faith-based organisations across Nigeria have trusted GAVI AFRICA with their vehicles.</p>
      </div>
      <div class="client-marquee" aria-label="Client logos scrolling">
        <div class="client-track">
          <span class="client-logo"><img src="/images/clients/client-amcon.png" alt="AMCON" loading="lazy" /></span>
          <span class="client-logo"><img src="/images/clients/client-bsn.png" alt="BSN — The Bible Society of Nigeria" loading="lazy" /></span>
          <span class="client-logo"><img src="/images/clients/client-firststandard.png" alt="First Standard Insurance Brokers" loading="lazy" /></span>
          <span class="client-logo"><img src="/images/clients/client-pfs.png" alt="Precise Financial Systems" loading="lazy" /></span>
          <span class="client-logo"><img src="/images/clients/client-valmon.png" alt="Valmon Securities" loading="lazy" /></span>
          <span class="client-logo"><img src="/images/clients/client-edgenet.png" alt="EdgeNet Consulting" loading="lazy" /></span>
          <span class="client-logo"><img src="/images/clients/client-corona.png" alt="Corona Secondary School, Agbara" loading="lazy" /></span>
          <span class="client-logo"><img src="/images/clients/client-solomongrace.png" alt="Solomon Grace Int'l Schools" loading="lazy" /></span>
          <span class="client-logo"><img src="/images/clients/client-dimeji.png" alt="Dimeji International School" loading="lazy" /></span>
          <span class="client-logo"><img src="/images/clients/client-inspired.png" alt="Inspired Christian Learning Center" loading="lazy" /></span>
          <span class="client-logo"><img src="/images/clients/client-cac-kpa.png" alt="CAC Kingdom Power Assembly" loading="lazy" /></span>
          <span class="client-logo"><img src="/images/clients/client-amcon.png" alt="AMCON" loading="lazy" /></span>
          <span class="client-logo"><img src="/images/clients/client-bsn.png" alt="BSN — The Bible Society of Nigeria" loading="lazy" /></span>
          <span class="client-logo"><img src="/images/clients/client-firststandard.png" alt="First Standard Insurance Brokers" loading="lazy" /></span>
          <span class="client-logo"><img src="/images/clients/client-pfs.png" alt="Precise Financial Systems" loading="lazy" /></span>
          <span class="client-logo"><img src="/images/clients/client-valmon.png" alt="Valmon Securities" loading="lazy" /></span>
          <span class="client-logo"><img src="/images/clients/client-edgenet.png" alt="EdgeNet Consulting" loading="lazy" /></span>
          <span class="client-logo"><img src="/images/clients/client-corona.png" alt="Corona Secondary School, Agbara" loading="lazy" /></span>
          <span class="client-logo"><img src="/images/clients/client-solomongrace.png" alt="Solomon Grace Int'l Schools" loading="lazy" /></span>
          <span class="client-logo"><img src="/images/clients/client-dimeji.png" alt="Dimeji International School" loading="lazy" /></span>
          <span class="client-logo"><img src="/images/clients/client-inspired.png" alt="Inspired Christian Learning Center" loading="lazy" /></span>
          <span class="client-logo"><img src="/images/clients/client-cac-kpa.png" alt="CAC Kingdom Power Assembly" loading="lazy" /></span>
        </div>
      </div>
      <p class="clients-more">…and many more across Nigeria.</p>
    </div>
  </section>

  <!-- ============ SECTION I: Workshop Gallery — NEW in v3 (photo slots for client) ============ -->
  <section class="gallery">
    <div class="container">
      <div class="gallery-header">
        <div>
          <span class="eyebrow">Inside the Centre</span>
          <h2 class="section-title">The facility, the floor, the team.</h2>
        </div>
        <p style="font-size: 15px; color: var(--ink-mute); max-width: 360px;">
          What you'll see when you walk through the gate. The bays, the diagnostics, the people working on your car, and the tools they work with.
        </p>
      </div>

      <!--
        ====================================================================
        PHOTO SLOT INSTRUCTIONS (for Saint)
        ====================================================================
        Each tile below shows a labelled placeholder with the dimensions
        and filename for the real photo. To swap in a real photo:

          1. Drop the image into /images/ at the spec'd dimensions.
          2. Replace the <div class="gallery-placeholder">…</div> with:
             <img src="/images/showroom-main.jpg" alt="GAVI AFRICA showroom" />
          3. The img will auto-cover the tile (object-fit: cover).

        Slot 1 (hero, wide):  showroom-main.jpg   3:2  · 1800×1200 min
        Slot 2:               workshop-floor.jpg  4:3  · 1200×900  min
        Slot 3:               diagnostics.jpg     4:3  · 1200×900  min
        Slot 4:               parts-counter.jpg   4:3  · 1200×900  min
        Slot 5:               quality-check.jpg   4:3  · 1200×900  min
        ====================================================================
      -->

      <div class="gallery-grid">

        <div class="gallery-tile">
          <!-- PHOTO SLOT 1 (HERO): replace with <img src="/images/showroom-main.jpg" alt="GAVI AFRICA showroom" /> -->
          <img src="/images/facility-front.jpg" alt="GAVI AFRICA Auto Experience Centre exterior" loading="lazy">
        </div>

        <div class="gallery-tile">
          <!-- PHOTO SLOT 2: replace with <img src="/images/workshop-floor.jpg" alt="Workshop floor with service lifts" /> -->
          <img src="/images/workshop-bay.jpg" alt="Workshop bay with vehicles in service" loading="lazy">
        </div>

        <div class="gallery-tile">
          <!-- PHOTO SLOT 3: replace with <img src="/images/diagnostics.jpg" alt="Diagnostic bay" /> -->
          <img src="/images/diagnostic-tablet.jpg" alt="Technician running vehicle diagnostics" loading="lazy">
        </div>

        <div class="gallery-tile">
          <!-- PHOTO SLOT 4: replace with <img src="/images/parts-counter.jpg" alt="Parts counter" /> -->
          <img src="/images/team-balcony.jpg" alt="GAVI AFRICA technician team" loading="lazy">
        </div>

        <div class="gallery-tile">
          <!-- PHOTO SLOT 5: replace with <img src="/images/quality-check.jpg" alt="Final quality check" /> -->
          <img src="/images/engine-work.jpg" alt="Technician working on an engine removal at the GAVI AFRICA workshop" loading="lazy">
        </div>

      </div>

      <!-- Instagram follow CTA -->
      <div class="gallery-instagram">
        <div class="gallery-instagram-text">
          <div class="gallery-instagram-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41 1.27-.06 1.65-.07 4.85-.07M12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.9.33 4.14.63a5.86 5.86 0 0 0-2.13 1.38A5.86 5.86 0 0 0 .63 4.14C.33 4.9.13 5.78.07 7.05.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.27.26 2.15.56 2.91.31.79.73 1.46 1.38 2.13.67.66 1.34 1.07 2.13 1.38.76.3 1.64.5 2.91.56C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c1.27-.06 2.15-.26 2.91-.56a5.86 5.86 0 0 0 2.13-1.38 5.86 5.86 0 0 0 1.38-2.13c.3-.76.5-1.64.56-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.27-.26-2.15-.56-2.91a5.86 5.86 0 0 0-1.38-2.13A5.86 5.86 0 0 0 19.86.63C19.1.33 18.22.13 16.95.07 15.67.01 15.26 0 12 0zm0 5.84a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.41-11.85a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88z"/></svg>
          </div>
          <div class="gallery-instagram-copy">
            <h4>See more on Instagram</h4>
            <p>Live updates from the floor: new builds, workshop wins, fleet visits.</p>
          </div>
        </div>
        <a href="https://instagram.com/gaviafricaltd" class="btn btn-outline">Follow @gaviafricaltd →</a>
      </div>

    </div>
  </section>

  <!-- ============ SECTION J: Location CTA — NEW (branded map placeholder) ============ -->
  <section class="location">
    <div class="container">
      <div class="location-grid">
        <div>
          <span class="eyebrow">Find Us</span>
          <h2 class="section-title">The GAVI AFRICA Auto Experience Centre.</h2>
          <p class="location-address">
            3, Abiodun Onitiri Avenue,<br>
            Awori Bus-Stop, Abule-Egba,<br>
            Lagos, Nigeria
          </p>
          <p class="location-hours">
            <strong>Mon–Fri:</strong> 8:00 AM – 5:00 PM<br>
            <strong>Saturday:</strong> 8:00 AM – 2:00 PM<br>
            <strong>Sunday:</strong> Closed<br>
            <em>Early Bird from 6:30 AM by booking — T&amp;Cs apply.</em>
          </p>
          <div class="location-ctas">
