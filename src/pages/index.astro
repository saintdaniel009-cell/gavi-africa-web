<script>
  // Booking form → Google Sheets via Apps Script web app.
  // Paste your deployed Apps Script /exec URL below.
  const SHEET_ENDPOINT = 'PASTE_YOUR_APPS_SCRIPT_URL_HERE'

  const bookingForm = document.getElementById('booking-form')
  if (bookingForm) {
      bookingForm.addEventListener('invalid', () => bookingForm.classList.add('show-errors'), true)
    bookingForm.addEventListener('submit', async (e) => {
      e.preventDefault()
      const btn = bookingForm.querySelector('button[type="submit"]')
      const original = btn.textContent
      btn.textContent = 'Sending…'
      btn.disabled = true
      try {
        const data = Object.fromEntries(new FormData(bookingForm).entries())
        data.submittedAt = new Date().toISOString()
        data.page = location.pathname
        await fetch(SHEET_ENDPOINT, {
          method: 'POST',
          mode: 'no-cors', // Apps Script doesn't return CORS headers; fire-and-forget
          headers: {'Content-Type': 'text/plain;charset=utf-8'},
          body: JSON.stringify(data),
        })
        btn.textContent = 'Request received ✓'
        bookingForm.reset()
        setTimeout(() => { btn.textContent = original; btn.disabled = false }, 4000)
      } catch (err) {
        btn.textContent = 'Something went wrong — call us instead'
        setTimeout(() => { btn.textContent = original; btn.disabled = false }, 4000)
      }
    })
  }
</script>

<script>
  // Hero carousel autoplay
  document.querySelectorAll('[data-carousel]').forEach((root) => {
    const slides = Array.from(root.querySelectorAll('.carousel-slide'))
    const dots   = Array.from(root.querySelectorAll('.carousel-dot'))
    if (slides.length < 2) return
    let current = 0
    let interval = null
    const goTo = (idx) => {
      slides[current].classList.remove('is-active')
      dots[current]?.classList.remove('is-active')
      current = (idx + slides.length) % slides.length
      slides[current].classList.add('is-active')
      dots[current]?.classList.add('is-active')
    }
    const next  = () => goTo(current + 1)
    const start = () => (interval = setInterval(next, 5000))
    const stop  = () => interval && clearInterval(interval)
    dots.forEach((dot, i) => dot.addEventListener('click', () => { stop(); goTo(i); start() }))
    root.addEventListener('mouseenter', stop)
    root.addEventListener('mouseleave', start)
    start()
  })
</script>

