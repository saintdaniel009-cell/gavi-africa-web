---
import Base from '../layouts/Base.astro'
import OemMarquee from '../components/OemMarquee.astro'
---

<Base
  title="About GAVI AFRICA LIMITED — Auto Experience Centre in Abule-Egba, Lagos"
  description="One centre for vehicle sales, service, and spare parts in Lagos, Nigeria. Working with Toyota, Bosch, Denso, Aisin, and Advics."
  activePage="about"
>
<!-- ============ PAGE HERO ============ -->
<section class="page-hero">
  <div class="container">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a><span class="crumb-sep">/</span>About
    </nav>
    <span class="eyebrow">ABOUT GAVI AFRICA LIMITED</span>
    <h1>One centre. Sales, service, and spare parts under one roof.</h1>
    <p class="lede">
      Most Lagos motorists juggle three relationships: a dealer to buy from, a mechanic to fix things, and a shop to source parts. We collapsed those three into one. Trained techs, OEM parts, real warranty, all on Abiodun Onitiri Avenue.
    </p>
  </div>
</section>

<!-- ============ STORY ============ -->
<section class="story-intro">
  <div class="container">
    <div class="story-grid">
      <div class="story-copy">
        <span class="eyebrow">OUR STORY</span>
        <h2>Built for the way people in Lagos drive.</h2>
        <p>
          GAVI AFRICA LIMITED runs an Auto Experience Centre in Abule-Egba, Lagos. We sell brand new and verified pre-owned vehicles. We service every car that comes through the gate. We supply genuine spare parts to walk-in customers, fleets, and other workshops.
        </p>
        <p>
          We work with <strong>Toyota Genuine Parts</strong> alongside independent OEM manufacturers: <strong>Bosch (Germany), Denso, Aisin, and Advics</strong>. Our supply network reaches well beyond these flagship partners.
        </p>
        <p>
          The centre serves individuals and families who want a single trusted place to keep their car running, and anyone with three or more vehicles who needs scheduled service, mobile-workshop visits, and one consolidated monthly bill — corporate fleet or otherwise.
        </p>
      </div>

      <div class="story-photo">
        <img src="/images/facility-front.jpg" alt="GAVI AFRICA Auto Experience Centre exterior" loading="lazy">
      </div>
    </div>
  </div>
</section>

<!-- ============ MISSION / VISION / VALUES ============ -->
<section class="mvv">
  <div class="container">
    <div class="center" style="margin-bottom: var(--s-10);">
      <span class="eyebrow">MISSION · VISION · VALUES</span>
      <h2 class="section-title">What we stand for.</h2>
      <p class="section-lede">Short version: we want car ownership in Lagos to feel less like a stress and more like a relationship.</p>
    </div>
    <div class="mvv-grid">
      <div class="mvv-card">
        <span class="mvv-label">Mission</span>
        <h3>World-class products and service.</h3>
        <p>Providing our corporate and individual customers with world-class products and services in the automotive and allied industries, through the application of the best technology and our team of customer-focused professionals, in meeting their needs and wants.</p>
      </div>
      <div class="mvv-card">
        <span class="mvv-label">Vision</span>
        <h3>The automobile enterprise of choice.</h3>
        <p>To be the leading world-class automobile enterprise of choice in Nigeria, creating value, exceeding customer expectations, and redefining excellence.</p>
      </div>
      <div class="mvv-card">
        <span class="mvv-label">Values</span>
        <h3>Six things we won't bend on.</h3>
        <p><strong>Customer-First. Competence. Commitment. Integrity. Reliability. Trust.</strong></p>
      </div>
    </div>
  </div>
</section>

<!-- ============ THE AUTO EXPERIENCE CENTRE ============ -->
<section class="centre">
  <div class="container">
    <div class="centre-grid">

      <div class="centre-photo">
        <img src="/images/facility-aerial-angle.jpg" alt="Aerial view of the GAVI AFRICA compound" loading="lazy">
      </div>

      <div>
        <span class="eyebrow on-dark">THE AUTO EXPERIENCE CENTRE</span>
        <h2 class="section-title">3, Abiodun Onitiri Avenue.</h2>
        <p>
          The centre houses a showroom, a service workshop, a diagnostics bay, a body and paint area, and the parts counter. One address, one phone number, one service advisor relationship.
        </p>
        <p>
          The car you bought from us last year is the same car your technician sees on the lift today. They already know its history.
        </p>
        <div class="centre-features">
          <div class="centre-feature">
            <h4>Showroom</h4>
            <p>New and pre-owned vehicles on the floor.</p>
          </div>
          <div class="centre-feature">
            <h4>Service workshop</h4>
            <p>Lifts, diagnostics, brand-trained techs.</p>
          </div>
          <div class="centre-feature">
            <h4>Body &amp; paint</h4>
            <p>Booth-cured finish, colour-matched.</p>
          </div>
          <div class="centre-feature">
            <h4>Parts counter</h4>
            <p>OEM stock for walk-ins and fleets.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ PARTNERS ============ -->
<section class="partners">
  <div class="container">
    <div class="center" style="margin-bottom: var(--s-10);">
      <span class="eyebrow">OEM PARTNERS</span>
      <h2 class="section-title">The brands we work with, across the industry.</h2>
      <p class="section-lede">Five flagship OEM partners anchor our parts catalogue: Toyota, Bosch, Denso, Aisin, and Advics. Beyond these, we source from a wide network of original-equipment manufacturers.</p>
    </div>
    <OemMarquee />
  </div>
</section>

<!-- ============ TEAM (hidden for now — client is in transition/hiring) ============ -->
<section class="team" style="padding-top: var(--s-12); padding-bottom: var(--s-12);">
  <div class="container">
    <div class="center" style="max-width: 640px; margin: 0 auto;">
      <span class="eyebrow">CAREERS</span>
      <h2 class="section-title">Want to join us?</h2>
      <p class="section-lede" style="margin-left: auto; margin-right: auto;">
        We're growing the team across service, sales, and parts. Send us a CV at
        <a href="mailto:hrpeople@gaviafrica.com" class="text-link">hrpeople@gaviafrica.com</a>.
      </p>
    </div>
  </div>
</section>

<!-- ============ DISCLAIMER (name clarity) ============ -->
<section class="disclaimer">
  <div class="container">
    <div class="disclaimer-card">
      <h3>A note on the name.</h3>
      <p>GAVI AFRICA LIMITED is a Nigerian automotive company registered with the Corporate Affairs Commission. We sell vehicles, service cars, and supply spare parts.</p>
      <p>We are not affiliated with <strong>Gavi, the Vaccine Alliance</strong>, the global health organisation. Different names. Different work. Just a coincidence of spelling.</p>
    </div>
  </div>
</section>

<!-- ============ BOTTOM CTA ============ -->
<section class="visit-cta">
  <div class="container">
    <div class="center-text">
      <h2>Come see the centre.</h2>
      <p>Walk in. Look at the showroom. Talk to a Service Advisor. See the workshop. The address is below, the kettle is on.</p>
      <div class="actions">
        <a href="/contact" class="btn btn-on-light">Get directions →</a>
        <a href="/#booking" class="btn btn-outline-light">Or book a service →</a>
      </div>
    </div>
  </div>
</section>
</Base>

<style>
/* About page */
  .story-intro { background: var(--paper); }
  .story-grid {
    display: grid; gap: var(--s-10);
    grid-template-columns: 1fr;
  }
  @media (min-width: 1024px) { .story-grid { grid-template-columns: 1.1fr 1fr; align-items: center; gap: var(--s-16); } }
  .story-copy h2 { font-size: 32px; margin-bottom: var(--s-5); }
  @media (min-width: 760px) { .story-copy h2 { font-size: 40px; } }
  .story-copy p {
    font-size: 16px; color: var(--ink-soft);
    line-height: 1.7; margin-bottom: var(--s-4);
  }
  .story-copy p strong { color: var(--ink); font-weight: 700; }
  @media (min-width: 760px) { .story-copy p { font-size: 17px; } }

  /* Photo slot for showroom (Saint will add) */
  .story-photo {
    position: relative;
    aspect-ratio: 4 / 5;
    background: var(--paper-soft);
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 16px 40px rgba(15, 26, 43, 0.10);
  }
  .story-photo img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
  }
  .story-photo-placeholder {
    position: absolute; inset: 0;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: var(--s-2);
    background:
      repeating-linear-gradient(135deg, rgba(36, 110, 182, 0.18) 0, rgba(36, 110, 182, 0.18) 14px, var(--paper-soft) 14px, var(--paper-soft) 28px);
  }
  .story-photo-label {
    background: var(--paper); border: 1.5px dashed var(--gavi-blue);
    padding: 8px 16px; border-radius: 999px;
    font-size: 12px; font-weight: 700; color: var(--gavi-blue);
    letter-spacing: 0.06em;
  }
  .story-photo-spec {
    font-size: 11px; color: var(--ink-mute);
    background: rgba(255,255,255,0.85);
    padding: 4px 10px; border-radius: 4px;
  }

  /* Mission/Vision/Values */
  .mvv { background: var(--paper-soft); }
  .mvv-grid {
    display: grid; gap: var(--s-6);
    grid-template-columns: 1fr;
  }
  @media (min-width: 880px) { .mvv-grid { grid-template-columns: repeat(3, 1fr); } }
  .mvv-card {
    background: var(--paper); border: 1px solid var(--line);
    border-radius: 16px; padding: var(--s-8);
    border-top: 5px solid var(--gavi-blue);
  }
  .mvv-card .mvv-label {
    font-size: 12px; font-weight: 700; color: var(--gavi-blue);
    letter-spacing: 0.16em; text-transform: uppercase;
    margin-bottom: var(--s-3);
  }
  .mvv-card h3 { font-size: 22px; margin-bottom: var(--s-4); }
  .mvv-card p { font-size: 15px; color: var(--ink-mute); line-height: 1.6; }

  /* The Auto Experience Centre */
  .centre {
    background: var(--ink); color: #D8E0EC;
    position: relative; overflow: hidden;
  }
  .centre h2, .centre h3, .centre h4 { color: #fff; }
  .centre::before {
    content: ''; position: absolute; top: -10%; left: -5%;
    width: 35%; height: 80%;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 60 70'><polygon points='30,0 60,17.5 60,52.5 30,70 0,52.5 0,17.5' fill='none' stroke='%235B96D0' stroke-width='1' opacity='0.5'/></svg>");
    background-size: 80px 92px; opacity: 0.18; pointer-events: none;
  }
  .centre > .container { position: relative; z-index: 1; }
  .centre-grid {
    display: grid; gap: var(--s-10);
    grid-template-columns: 1fr;
    align-items: center;
  }
  @media (min-width: 1024px) { .centre-grid { grid-template-columns: 1fr 1.1fr; gap: var(--s-16); } }
  .centre p { color: #B8C5D6; font-size: 16px; line-height: 1.7; margin-bottom: var(--s-4); }

  /* Photo slot for workshop (dark variant) */
  .centre-photo {
    position: relative;
    aspect-ratio: 4 / 3;
    background: var(--ink-soft);
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid #2A3A52;
  }
  .centre-photo img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
  }
  .centre-photo-placeholder {
    position: absolute; inset: 0;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: var(--s-2);
    background:
      repeating-linear-gradient(135deg, rgba(36, 110, 182, 0.18) 0, rgba(36, 110, 182, 0.18) 14px, rgba(31, 45, 66, 0.6) 14px, rgba(31, 45, 66, 0.6) 28px);
  }
  .centre-photo-label {
    background: rgba(255,255,255,0.1); border: 1.5px dashed rgba(255,255,255,0.5);
    padding: 8px 16px; border-radius: 999px;
    font-size: 12px; font-weight: 700; color: #fff;
    letter-spacing: 0.06em;
  }
  .centre-photo-spec {
    font-size: 11px; color: rgba(255,255,255,0.65);
    background: rgba(0,0,0,0.3);
    padding: 4px 10px; border-radius: 4px;
  }

  .centre-features {
    display: grid; gap: var(--s-5); margin-top: var(--s-6);
    grid-template-columns: 1fr;
  }
  @media (min-width: 540px) { .centre-features { grid-template-columns: 1fr 1fr; } }
  .centre-feature {
    border-left: 2px solid var(--gavi-blue);
    padding-left: var(--s-4);
  }
  .centre-feature h4 { font-size: 16px; margin-bottom: var(--s-1); }
  .centre-feature p { font-size: 13px; color: #B8C5D6; margin-bottom: 0; line-height: 1.5; }

  /* Partners section */
  .partners { background: var(--paper); }
  .partners-grid {
    display: grid; gap: var(--s-6);
    grid-template-columns: 1fr;
  }
  @media (min-width: 540px)  { .partners-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .partners-grid { grid-template-columns: repeat(5, 1fr); } }
  .partner-card {
    background: var(--paper-soft); border: 1px solid var(--line);
    border-radius: 12px; padding: var(--s-6); text-align: center;
  }
  .partner-name {
    font-weight: 900; font-size: 22px;
    letter-spacing: 0.02em; margin-bottom: var(--s-2);
  }
  .partner-name.toyota { color: var(--toyota-red); font-style: italic; }
  .partner-name.bosch  { color: var(--bosch-red); }
  .partner-name.denso  { color: var(--denso-blue); }
  .partner-name.aisin  { color: var(--aisin-navy); }
  .partner-name.advics { color: var(--advics-red); }
  .partner-role { font-size: 12px; color: var(--ink-mute); font-weight: 600; }

  
  /* Team section */
  .team { background: var(--paper-soft); }
  .team-grid {
    display: grid; gap: var(--s-6);
    grid-template-columns: 1fr;
  }
  @media (min-width: 540px)  { .team-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 880px)  { .team-grid { grid-template-columns: repeat(3, 1fr); } }
  .team-card {
    background: var(--paper); border: 1px solid var(--line);
    border-radius: 14px; overflow: hidden;
  }
  /* Team photo placeholder */
  .team-photo {
    aspect-ratio: 1 / 1;
    background: var(--paper-soft);
    position: relative; overflow: hidden;
    border-bottom: 1px solid var(--line);
  }
  .team-photo img {
    position: absolute; inset: 0;
    width: 100%; height: 100%; object-fit: cover;
  }
  .team-photo-placeholder {
    position: absolute; inset: 0;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: var(--s-2);
    background:
      repeating-linear-gradient(135deg, var(--gavi-blue-tint) 0, var(--gavi-blue-tint) 12px, var(--paper-soft) 12px, var(--paper-soft) 24px);
  }
  .team-photo-placeholder-label {
    background: var(--paper); border: 1.5px dashed var(--gavi-blue);
    padding: 6px 14px; border-radius: 999px;
    font-size: 11px; font-weight: 700; color: var(--gavi-blue);
  }
  .team-photo-placeholder-spec {
    font-size: 10px; color: var(--ink-mute);
    background: rgba(255,255,255,0.85);
    padding: 2px 8px; border-radius: 4px;
  }
  .team-body { padding: var(--s-5); }
  .team-name { font-size: 18px; margin-bottom: var(--s-1); }
  .team-role {
    font-size: 12px; color: var(--gavi-blue);
    text-transform: uppercase; letter-spacing: 0.08em;
    font-weight: 700; margin-bottom: var(--s-3);
  }
  .team-bio { font-size: 14px; color: var(--ink-mute); line-height: 1.5; }

  /* Disclaimer section */
  .disclaimer { background: var(--paper); }
  .disclaimer-card {
    background: var(--paper-soft); border: 1px solid var(--line);
    border-left: 4px solid var(--gavi-blue);
    border-radius: 8px; padding: var(--s-6);
    max-width: 760px; margin: 0 auto;
  }
  .disclaimer-card h3 { font-size: 18px; margin-bottom: var(--s-3); }
  .disclaimer-card p { font-size: 14px; color: var(--ink-soft); line-height: 1.6; margin-bottom: var(--s-2); }
  .disclaimer-card p:last-child { margin-bottom: 0; }

  /* Bottom CTA */
  .visit-cta { background: var(--gavi-blue); color: #fff; padding: var(--s-12) 0; }
  .visit-cta .center-text { text-align: center; }
  .visit-cta h2 { color: #fff; font-size: 32px; margin-bottom: var(--s-4); }
  @media (min-width: 760px) { .visit-cta h2 { font-size: 40px; } }
  .visit-cta p {
    color: rgba(255,255,255,0.9); font-size: 17px;
    max-width: 560px; margin: 0 auto var(--s-6);
  }
  .visit-cta .actions {
    display: flex; gap: var(--s-3); justify-content: center; flex-wrap: wrap;
  }
  .visit-cta .btn-on-light { background: #fff; color: var(--gavi-blue); }
  .visit-cta .btn-on-light:hover { background: var(--gavi-blue-tint); }
  .visit-cta .btn-outline-light { background: transparent; color: #fff; border: 2px solid #fff; }
  .visit-cta .btn-outline-light:hover { background: rgba(255,255,255,0.1); }
</style>
